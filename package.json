{
  "name": "dark-matrix",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dark-matrix": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "node --watch dist/daemon/index.js",
    "build": "tsc && npm run build:designer",
    "build:designer": "esbuild src/designer/web/main.ts --bundle --format=esm --outfile=dist/designer/web/main.js --target=es2022 && cp src/designer/web/index.html dist/designer/web/index.html && cp src/designer/web/style.css dist/designer/web/style.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fft.js": "^4.0.4",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild",
      "sharp"
    ]
  }
}
