{
  "name": "dark-matrix",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dark-matrix": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "node --watch dist/daemon/index.js",
    "dev:designer": "vite",
    "dev:all": "concurrently -n daemon,designer,vite -c blue,yellow,green \"node --watch dist/daemon/index.js\" \"node dist/cli/index.js designer\" \"vite\"",
    "build": "tsc && vite build",
    "build:designer": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.169.2",
    "clsx": "^2.1.1",
    "fft.js": "^4.0.4",
    "lucide-react": "^1.14.0",
    "react": "^19",
    "react-dom": "^19",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.0.0",
    "vite": "^6",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild",
      "sharp"
    ]
  }
}
