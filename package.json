{
  "name": "dark-matrix",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dark-matrix": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "node --watch dist/daemon/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fft.js": "^4.0.4",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild",
      "sharp"
    ]
  }
}
