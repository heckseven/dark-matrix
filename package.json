{
  "name": "dark-matrix",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/",
    "systemd/",
    "udev/",
    "images/"
  ],
  "bin": {
    "dark-matrix": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "node --watch dist/daemon/index.js",
    "dev:deck": "vite",
    "dev:all": "concurrently -n daemon,deck,vite -c blue,yellow,green \"node --watch dist/daemon/index.js\" \"node dist/cli/index.js ui\" \"vite\"",
    "build": "tsc && vite build && node scripts/build-bundles.mjs",
    "build:deck": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fft.js": "^4.0.4",
    "react": "^19.2.6",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.6",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "storybook": "10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild",
      "sharp"
    ]
  }
}
