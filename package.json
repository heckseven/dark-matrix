{
  "name": "dark-matrix",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dark-matrix": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "node --watch dist/daemon/index.js",
    "dev:designer": "vite",
    "dev:all": "concurrently -n daemon,designer,vite -c blue,yellow,green \"node --watch dist/daemon/index.js\" \"node dist/cli/index.js designer\" \"vite\"",
    "build": "tsc && vite build",
    "build:designer": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-router": "^1.169.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fft.js": "^4.0.4",
    "lucide-react": "^1.14.0",
    "react": "^19",
    "react-dom": "^19",
    "serialport": "^12.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.0-next.0",
    "@storybook/addon-a11y": "10.4.0-alpha.18",
    "@storybook/addon-docs": "10.4.0-alpha.18",
    "@storybook/addon-mcp": "^0.1.4-next.2",
    "@storybook/addon-vitest": "10.4.0-alpha.18",
    "@storybook/tanstack-react": "10.4.0-alpha.18",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "storybook": "10.4.0-alpha.18",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.0.0",
    "vite": "^6",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild",
      "sharp"
    ]
  }
}
